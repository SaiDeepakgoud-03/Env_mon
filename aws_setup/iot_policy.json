{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowConnectAsThisDevice",
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:us-east-1:*:client/esp32-env-*"
    },
    {
      "Sid": "AllowPublishOnEnvironmentTopic",
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": "arn:aws:iot:us-east-1:*:topic/environment/data"
    },
    {
      "Sid": "AllowSubscribeOnEnvironmentTopic",
      "Effect": "Allow",
      "Action": "iot:Subscribe",
      "Resource": "arn:aws:iot:us-east-1:*:topicfilter/environment/*"
    },
    {
      "Sid": "AllowReceiveOnEnvironmentTopic",
      "Effect": "Allow",
      "Action": "iot:Receive",
      "Resource": "arn:aws:iot:us-east-1:*:topic/environment/*"
    }
  ]
}
